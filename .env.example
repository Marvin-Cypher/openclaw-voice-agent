# OpenAI (needs Realtime API access)
OPENAI_API_KEY=sk-proj-...

# Twilio (Voice + Media Streams)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Composio MCP (optional — for Gmail, Calendar, Slack, etc.)
# Get your tool router URL from https://composio.dev
COMPOSIO_MCP_URL=https://backend.composio.dev/tool_router/trs_XXXXX/mcp
COMPOSIO_API_KEY=ak_...

# Server
PORT=19000
PUBLIC_URL=https://your-cvm-url:19000/voice/webhook

# Inbound policy: comma-separated allowed caller IDs (empty = allow all)
ALLOWED_CALLERS=

# OpenClaw integration (paths inside the CVM container)
OPENCLAW_SKILLS_DIR=/root/.openclaw/skills
OPENCLAW_MEMORY_DB=/data/openclaw/memory/main.sqlite
